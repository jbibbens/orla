# Tasks for the HotpotQA distractor example. Requires uv.

# List recipes.
default:
    @just --list

# Run the benchmark (override the sample size with N, e.g. `N=50 just run`).
run:
    uv run run.py

# Format the code with ruff.
fmt:
    uv run ruff format .

# Lint with ruff (use `just lint --fix` to apply fixes).
lint *args:
    uv run ruff check {{ args }} .

# Type-check with ty.
typecheck:
    uv run ty check .

# Read-only checks, the way CI would run them.
check:
    uv run ruff format --check .
    uv run ruff check .
    uv run ty check .

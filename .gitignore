#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.out
coverage.html
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Build output
bin/

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

.DS_Store

# SWE-bench Lite dataset (committed as dataset.zip; unzipped in Docker)
examples/swe_bench_lite/dataset/dev/
examples/swe_bench_lite/dataset/test/